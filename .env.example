# ============================================================================
# Supabase
# ============================================================================
# Récupérer depuis https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Clé service-role (ne jamais exposer côté client !)
# Utilisée par le webhook Lemon Squeezy pour bypasser la RLS lors des updates
# de profiles.subscription_status et insertions dans referral_earnings.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# Application
# ============================================================================

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# Lemon Squeezy (Premium)
# ============================================================================
# Setup : voir gametrend/docs/SETUP_LEMON_SQUEEZY.md

LEMON_API_KEY=
LEMON_STORE_ID=
LEMON_WEBHOOK_SECRET=
LEMON_VARIANT_ID_MONTHLY=
LEMON_VARIANT_ID_YEARLY=
LEMON_VARIANT_ID_LIFETIME=

# ============================================================================
# Resend (emails transactionnels)
# ============================================================================
# https://resend.com/api-keys

RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@gametrend.fr

# ============================================================================
# PostHog (analytics produit)
# ============================================================================
# Compte EU Cloud : https://eu.posthog.com

NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ============================================================================
# Google AdSense (monétisation)
# ============================================================================
# Publisher ID au format ca-pub-XXXXXXXXXXXXXXXX
# Récupérer depuis https://www.google.com/adsense/new/u/0/pub-.../home
# Si vide → script non chargé (utile en dev/preview).

NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Slot IDs des unités d'annonces (10 chiffres chacun).
# À récupérer depuis Console AdSense → Annonces → Par unité publicitaire.
# Si l'un est vide, le slot correspondant ne s'affiche pas.

NEXT_PUBLIC_ADSENSE_SLOT_FEED=
NEXT_PUBLIC_ADSENSE_SLOT_EXPLORE=
NEXT_PUBLIC_ADSENSE_SLOT_PRESET=

# ============================================================================
# Navi — Arbitre IA (premium uniquement, jeu Outbid)
# ============================================================================
# Clé API OpenAI : https://platform.openai.com/api-keys
# Modèle utilisé par défaut : gpt-5-nano (rapide, très bon marché).
# Surchargez NAVI_MODEL pour tester un autre modèle compatible Chat Completions.

OPENAI_API_KEY=
NAVI_MODEL=gpt-5-nano
