# ============================================================================
# Supabase
# ============================================================================
# Récupérer depuis https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Clé service-role (ne jamais exposer côté client !)
# Utilisée par le webhook Lemon Squeezy pour bypasser la RLS lors des updates
# de profiles.subscription_status et insertions dans referral_earnings.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# Application
# ============================================================================

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# Lemon Squeezy (Premium)
# ============================================================================
# Setup : voir gametrend/docs/SETUP_LEMON_SQUEEZY.md

LEMON_API_KEY=
LEMON_STORE_ID=
LEMON_WEBHOOK_SECRET=
LEMON_VARIANT_ID_MONTHLY=
LEMON_VARIANT_ID_YEARLY=
LEMON_VARIANT_ID_LIFETIME=

# ============================================================================
# Resend (emails transactionnels)
# ============================================================================
# https://resend.com/api-keys

RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@gametrend.fr

# ============================================================================
# PostHog (analytics produit)
# ============================================================================
# Compte EU Cloud : https://eu.posthog.com

NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
